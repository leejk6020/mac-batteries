<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Mac App Store distribution. Battery levels are read from the
         IORegistry, which needs no further entitlement, so nothing else is claimed. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
</dict>
</plist>
